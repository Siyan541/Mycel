        offsets[id] = { dx: (nm[id] ? nm[id].x : 0) - hit.x, dy: (nm[id] ? nm[id].y : 0) - hit.y };
      });
      setDrag({ t: 'c', nid: hit.id, nbrs: nbrs, sx: sx, sy: sy, ox: hit.x, oy: hit.y, off: offsets });
